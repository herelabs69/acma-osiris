# ============================================================
#  OSIRIS — ตัวอย่างไฟล์ Environment Variables
#  คัดลอกไฟล์นี้เป็น .env (สำหรับรันในเครื่อง)
#  หรือไปตั้งค่าใน Netlify: Site settings → Environment variables
#
#  ** ระบบทำงานได้ทันทีโดยไม่ต้องใส่ค่าใด ๆ **
#  ฟีดข้อมูลหลักทุกตัวใช้แหล่งสาธารณะที่ไม่ต้องมี API key
#  ค่าด้านล่างนี้ใส่เพิ่มเฉพาะเมื่อต้องการเปิดฟีเจอร์/เพิ่ม rate limit
# ============================================================

# --- RECON Scanner (สแกนพอร์ต/ช่องโหว่) ---
# ถ้าไม่ใส่ แท็บ "สแกนพอร์ต/สแกนช่องโหว่" จะคืนค่า 503 (ฟีเจอร์อื่นใช้ได้ปกติ)
# ต้องมี backend แยก และ SCANNER_KEY ต้องตรงกับ OSIRIS_KEY ของ backend
# สร้าง key: openssl rand -hex 32
SCANNER_URL=
SCANNER_KEY=

# --- เพิ่ม rate limit / ฟีเจอร์เสริม (ไม่บังคับ) ---
FIRMS_API_KEY=                 # NASA FIRMS (ไฟป่า) — firms.modaps.eosdis.nasa.gov/api/map_key/
OPENSKY_CLIENT_ID=             # OpenSky (เครื่องบิน) OAuth2 — opensky-network.org
OPENSKY_CLIENT_SECRET=
N2YO_API_KEY=                  # N2YO (ดาวเทียม) — n2yo.com (Profile → API key)
AIS_API_KEY=                   # aisstream.io (เรือ)

# --- ตัวช่วยวิเคราะห์ AI (ไม่บังคับ) ---
GEMINI_API_KEY=                # Google Gemini — aistudio.google.com/apikey
